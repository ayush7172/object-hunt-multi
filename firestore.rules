rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Room documents
    match /rooms/{roomId} {
      // Anyone can read room state (for lobby)
      allow read: if true;
      
      // Only host can create rooms
      allow create: if request.auth != null 
        && request.resource.data.hostId == request.auth.uid;
      
      // Host can update room settings and phase
      // Players can update their own player state
      allow update: if request.auth != null && (
        // Host updates
        resource.data.hostId == request.auth.uid
        // Player updates their own state
        || request.auth.uid in request.resource.data.players.keys()
      );
      
      // Only host can delete rooms
      allow delete: if request.auth != null 
        && resource.data.hostId == request.auth.uid;
    }
  }
}

service cloud.firestore {
  match /databases/{database}/documents {
    match /signaling/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}